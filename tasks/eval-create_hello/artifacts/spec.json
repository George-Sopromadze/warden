{
  "goal": "Create a simple Python module hello.py that prints 'hello world' along with a pytest test file test_hello.py that imports and validates the module.",
  "scope": [
    "Create hello.py that prints 'hello world'",
    "Create test_hello.py with pytest tests that import and verify hello.py",
    "Ensure all tests pass"
  ],
  "out_of_scope": [
    "Creating setup.py or packaging configuration",
    "Project documentation or README files",
    "Multiple implementations or configuration options",
    "CI/CD or build automation"
  ],
  "acceptance_criteria": [
    {
      "id": "AC-1",
      "type": "executable",
      "check": "test -f hello.py"
    },
    {
      "id": "AC-2",
      "type": "executable",
      "check": "python3 hello.py | grep -q 'hello world'"
    },
    {
      "id": "AC-3",
      "type": "executable",
      "check": "test -f test_hello.py"
    },
    {
      "id": "AC-4",
      "type": "executable",
      "check": "python3 -m pytest test_hello.py -v"
    },
    {
      "id": "AC-5",
      "type": "judgment",
      "check": "Does test_hello.py import hello.py and validate that it prints 'hello world'?"
    }
  ]
}
