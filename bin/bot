#!/usr/bin/env bash
# Manage the WARDEN approval bot via launchd.
#   bin/bot start | stop | status | restart | logs
# The bot runs as a launchd service (com.warden.bot) with KeepAlive, so it
# auto-restarts on a real crash. To genuinely stop it we must tell launchd to
# let go (bootout), otherwise KeepAlive immediately resurrects it.
ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$ROOT" || exit 1
LOGFILE="$ROOT/tasks/.bot.log"
mkdir -p "$ROOT/tasks"

LABEL="com.warden.bot"
PLIST="$HOME/Library/LaunchAgents/${LABEL}.plist"
DOMAIN="gui/$(id -u)"

running_pid() {
  pgrep -f "pipeline/approval_bot.py" 2>/dev/null | head -1
}
is_loaded() {
  launchctl list 2>/dev/null | grep -q "$LABEL"
}

cmd="${1:-status}"
case "$cmd" in
  start)
    if is_loaded; then
      pid="$(running_pid)"
      echo "bot already running (pid ${pid:-?})"; exit 0
    fi
    if [ ! -f "$PLIST" ]; then
      echo "launchd plist not found at $PLIST - run bin/install-autostart first"; exit 1
    fi
    launchctl bootstrap "$DOMAIN" "$PLIST" 2>/dev/null || launchctl load "$PLIST" 2>/dev/null
    sleep 2
    pid="$(running_pid)"
    if [ -n "$pid" ]; then
      echo "bot started (pid $pid) - logs: bin/bot logs"
    else
      echo "bot failed to start - last log lines:"; tail -5 "$LOGFILE" 2>/dev/null; exit 1
    fi
    ;;
  stop)
    if ! is_loaded && [ -z "$(running_pid)" ]; then
      echo "bot not running"; exit 0
    fi
    launchctl bootout "$DOMAIN/$LABEL" 2>/dev/null || launchctl unload "$PLIST" 2>/dev/null
    sleep 1
    pkill -f "pipeline/approval_bot.py" 2>/dev/null
    sleep 1
    if [ -z "$(running_pid)" ]; then echo "bot stopped"; else echo "bot still running - check 'launchctl list | grep warden'"; fi
    ;;
  restart) "$0" stop; sleep 1; "$0" start ;;
  status)
    pid="$(running_pid)"
    if [ -n "$pid" ]; then
      echo "bot running (pid $pid)"
    else
      echo "bot not running"
    fi
    ;;
  logs)
    [ -f "$LOGFILE" ] && tail -f "$LOGFILE" || echo "no log yet (start the bot first)"
    ;;
  *) echo "usage: bin/bot {start|stop|status|restart|logs}"; exit 1 ;;
esac
