#!/usr/bin/env bash
# Manage the WARDEN approval bot via launchd.
#   bin/bot start | stop | status | restart | logs
# The bot runs as a launchd service (com.warden.bot) with KeepAlive, so it
# auto-restarts on a real crash. To genuinely stop it we must tell launchd to
# let go (bootout), otherwise KeepAlive immediately resurrects it.
# A deliberate stop/start also pauses/resumes the heartbeat monitor, so you
# don't get "down" alerts for a bot you intentionally stopped. While the bot is
# meant to be running, the heartbeat stays loaded and alerts on a real crash.
ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$ROOT" || exit 1
LOGFILE="$ROOT/tasks/.bot.log"
mkdir -p "$ROOT/tasks"

DOMAIN="gui/$(id -u)"
BOT_LABEL="com.warden.bot"
HB_LABEL="com.warden.heartbeat"
BOT_PLIST="$HOME/Library/LaunchAgents/${BOT_LABEL}.plist"
HB_PLIST="$HOME/Library/LaunchAgents/${HB_LABEL}.plist"

running_pid() {
  pgrep -f "pipeline/approval_bot.py" 2>/dev/null | head -1
}
is_loaded() {
  launchctl list 2>/dev/null | grep -q "$1"
}
load_agent() {
  local label="$1" plist="$2"
  [ -f "$plist" ] || return 0
  is_loaded "$label" && return 0
  launchctl bootstrap "$DOMAIN" "$plist" 2>/dev/null || launchctl load "$plist" 2>/dev/null
}
unload_agent() {
  local label="$1" plist="$2"
  launchctl bootout "$DOMAIN/$label" 2>/dev/null || launchctl unload "$plist" 2>/dev/null
}

cmd="${1:-status}"
case "$cmd" in
  start)
    if is_loaded "$BOT_LABEL"; then
      echo "bot already running (pid $(running_pid))"
    else
      if [ ! -f "$BOT_PLIST" ]; then
        echo "launchd plist not found at $BOT_PLIST - run bin/install-autostart first"; exit 1
      fi
      load_agent "$BOT_LABEL" "$BOT_PLIST"
      sleep 2
      pid="$(running_pid)"
      if [ -n "$pid" ]; then
        echo "bot started (pid $pid) - logs: bin/bot logs"
      else
        echo "bot failed to start - last log lines:"; tail -5 "$LOGFILE" 2>/dev/null; exit 1
      fi
    fi
    # resume heartbeat monitoring
    load_agent "$HB_LABEL" "$HB_PLIST" && echo "heartbeat monitoring resumed"
    ;;
  stop)
    if ! is_loaded "$BOT_LABEL" && [ -z "$(running_pid)" ]; then
      echo "bot not running"
    else
      unload_agent "$BOT_LABEL" "$BOT_PLIST"
      sleep 1
      pkill -f "pipeline/approval_bot.py" 2>/dev/null
      sleep 1
      if [ -z "$(running_pid)" ]; then echo "bot stopped"; else echo "bot still running - check 'launchctl list | grep warden'"; fi
    fi
    # pause heartbeat so a deliberate stop doesn't trigger "down" alerts
    if is_loaded "$HB_LABEL"; then
      unload_agent "$HB_LABEL" "$HB_PLIST"
      echo "heartbeat monitoring paused (resumes on 'bin/bot start')"
    fi
    ;;
  restart) "$0" stop; sleep 1; "$0" start ;;
  status)
    pid="$(running_pid)"
    [ -n "$pid" ] && echo "bot running (pid $pid)" || echo "bot not running"
    is_loaded "$HB_LABEL" && echo "heartbeat: active" || echo "heartbeat: paused"
    ;;
  logs)
    [ -f "$LOGFILE" ] && tail -f "$LOGFILE" || echo "no log yet (start the bot first)"
    ;;
  *) echo "usage: bin/bot {start|stop|status|restart|logs}"; exit 1 ;;
esac
