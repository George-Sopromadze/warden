#!/usr/bin/env bash
# Manage the WARDEN approval bot with one command.
#   bin/bot start | stop | status | restart | logs
# No `set -e`: pgrep/pkill return non-zero on "no match", which is normal here.

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$ROOT" || exit 1
LOGFILE="$ROOT/tasks/.bot.log"
mkdir -p "$ROOT/tasks"

running_pid() {
  pgrep -f "pipeline/approval_bot.py" 2>/dev/null | head -1
}

cmd="${1:-status}"
case "$cmd" in
  start)
    pid="$(running_pid)"
    if [ -n "$pid" ]; then echo "bot already running (pid $pid)"; exit 0; fi
    nohup python3 pipeline/approval_bot.py > "$LOGFILE" 2>&1 &
    sleep 2
    pid="$(running_pid)"
    if [ -n "$pid" ]; then
      echo "bot started (pid $pid) - logs: bin/bot logs"
    else
      echo "bot failed to start - last log lines:"; tail -5 "$LOGFILE" 2>/dev/null; exit 1
    fi
    ;;
  stop)
    pid="$(running_pid)"
    if [ -z "$pid" ]; then echo "bot not running"; else
      pkill -f "pipeline/approval_bot.py" 2>/dev/null; sleep 1; echo "bot stopped"
    fi
    ;;
  restart) "$0" stop; "$0" start ;;
  status)
    pid="$(running_pid)"
    [ -n "$pid" ] && echo "bot running (pid $pid)" || echo "bot not running"
    ;;
  logs)
    [ -f "$LOGFILE" ] && tail -f "$LOGFILE" || echo "no log yet (start the bot first)"
    ;;
  *) echo "usage: bin/bot {start|stop|status|restart|logs}"; exit 1 ;;
esac
