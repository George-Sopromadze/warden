{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "WARDEN spec artifact",
  "type": "object",
  "required": [
    "goal",
    "scope",
    "out_of_scope",
    "acceptance_criteria"
  ],
  "additionalProperties": false,
  "properties": {
    "goal": {
      "type": "string",
      "minLength": 10
    },
    "scope": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "out_of_scope": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "acceptance_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "type",
          "check"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^AC-[0-9]+$"
          },
          "type": {
            "enum": [
              "executable",
              "judgment"
            ]
          },
          "check": {
            "type": "string",
            "minLength": 5,
            "description": "For type 'executable': a literal shell command that exits 0 on success and non-zero on failure (e.g. 'python3 -m pytest test_x.py'). NOT a prose description. For type 'judgment': a yes/no question."
          },
          "expected": {
            "type": "string"
          }
        }
      }
    },
    "flags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}