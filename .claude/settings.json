{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/hooks/pretooluse.py" }
        ]
      }
    ],
    "Stop": [
      { "hooks": [ { "type": "command", "command": "$CLAUDE_PROJECT_DIR/hooks/notify.sh" } ] }
    ],
    "SubagentStop": [
      { "hooks": [ { "type": "command", "command": "$CLAUDE_PROJECT_DIR/hooks/notify.sh" } ] }
    ]
  }
}
