# Copy to ~/.warden/secrets.env (NOT into the repo) and fill in:
#   mkdir -p ~/.warden && cp secrets.env.example ~/.warden/secrets.env
# Token from @BotFather; numeric user id from @userinfobot (never a username).
TELEGRAM_BOT_TOKEN=
TELEGRAM_USER_ID=
# Optional: heartbeat monitoring ping URL from healthchecks.io
HEALTHCHECK_URL=
